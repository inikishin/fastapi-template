# FastAPI application
PROJECT_TITLE="Start FastAPI service"  # Human-readable API title shown in Swagger
PROJECT_HOST=0.0.0.0                   # Bind host for uvicorn
PROJECT_PORT=8000                      # Bind port for uvicorn
PROJECT_DOCS_VERSION=1.0.0             # API version displayed in Swagger
PROJECT_DOCS_URL=/api/openapi          # Swagger UI path
PROJECT_OPENAPI_URL=/api/openapi.json  # OpenAPI schema path

# PostgreSQL — runtime database connection
DB_DRIVER_NAME=postgresql+asyncpg      # SQLAlchemy driver name
DB_HOST=localhost                      # Database host
DB_PORT=5432                           # Database port
DB_NAME=template                       # Database name
DB_USER=demo                           # Database user
DB_PASS=demo                           # Database password
DB_SHOW_QUERIES=false                  # Echo SQL statements into stdout (dev only)

# PostgreSQL — automated tests
DB_TEST_DATABASE_NAME=template_test    # Dedicated DB name for pytest runs (recreated every run)
